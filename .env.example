# Myah OSS — environment variables for the platform container.
#
# Copy this file to `.env` (one level up, at the repo root) and customize.
# `scripts/setup-myah-oss.sh` generates the agent-bearer token automatically.
#
# Everything in here is single-user OSS scope. Hosted-product secrets
# (Honcho admin key, Composio, OTel, Sentry, Langfuse) are NOT shipped in
# OSS — see PRIVACY.md and `docs/oss-vs-hosted.md` for the reasoning.

# ─── LLM Provider (optional override; default routes through hermes) ─────────
OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# ─── CORS / Proxy ────────────────────────────────────────────────────────────
# For production you should only need one host because fastapi serves the
# svelte-kit build and the backend API from the same host+port. To test CORS
# locally, set something like:
#   CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# Match the proxy configuration (127.0.0.1 for nginx/caddy in front of fastapi).
FORWARDED_ALLOW_IPS='*'

# ─── Database ────────────────────────────────────────────────────────────────
# Leave unset for SQLite (default, recommended for OSS).
# For Postgres: `postgresql://user:password@host:5432/dbname`.
# DATABASE_URL=

# ─── Myah ↔ Hermes Agent ─────────────────────────────────────────────────────
# Shared secret between this platform and your host-side hermes. Generated
# by `scripts/setup-myah-oss.sh` on first run.
MYAH_AGENT_BEARER_TOKEN='change-me-or-run-setup-myah-oss.sh'

# Override only if your hermes runs on non-default ports. The platform reaches
# hermes at `host.docker.internal:<port>` (the compose extra_hosts mapping
# resolves this on Mac/Windows/Linux).
# MYAH_HERMES_CHAT_PORT=8642
# MYAH_HERMES_GATEWAY_PORT=8643
# MYAH_HERMES_WEB_PORT=9119

# ─── OSS single-user behavior ────────────────────────────────────────────────
# Tells the backend to skip multi-user paths (sign-up, login, OAuth) and
# auto-create an anonymous admin user on first DB init. Required for OSS mode.
# If you want multi-user, you want the hosted Myah variant — see app.myah.dev.
MYAH_DEPLOYMENT_MODE=oss

# MYAH_AUTH=false is the single-user OSS default. The oss_seed_user Alembic
# migration inserts the anonymous admin on first boot. Setting this to `true`
# in an OSS deployment WILL break: the sign-up / login endpoints were moved
# to platform-hosted/ in Phase 1B (anti-SaaS surgical removal). Multi-user
# OSS is not a supported configuration — use app.myah.dev for that.
MYAH_AUTH=false

# ─── Logging (optional) ──────────────────────────────────────────────────────
# LOG_FORMAT=json
