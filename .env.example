OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave unset to use SQLite (default, recommended for dev and single-server beta)
# Set to a PostgreSQL URL for multi-server or managed-DB deployments:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Myah / Hermes Agent ──────────────────────────────────────────────────────
MYAH_AGENT_IMAGE=myah/agent:latest
MYAH_AGENT_BEARER_TOKEN=your-secret-token-here
OPENROUTER_API_KEY=your-openrouter-key-here

# ─── Honcho Memory ────────────────────────────────────────────────────────────
HONCHO_ADMIN_KEY=your-honcho-admin-key-here

# ─── Composio ────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=<your-composio-api-key>

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_FORMAT=json

####################################
# OPENTELEMETRY (Grafana Cloud)
####################################
# Enable the full OTEL stack — traces, metrics, and logs forwarded to Grafana Cloud via Alloy
# ENABLE_OTEL=true
# ENABLE_OTEL_TRACES=true
# ENABLE_OTEL_METRICS=true
# # Alloy listens on localhost:4317 (installed as systemd service on VPS host)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_SERVICE_NAME=myah-platform

# ─── Sentry error tracking, tracing & session replay ─────────────────────────
# All three layers use separate Sentry projects so errors are grouped cleanly.
# Get DSNs from: https://sentry.io/settings/projects/
SENTRY_DSN_PLATFORM=        # FastAPI backend — errors + distributed traces
SENTRY_DSN_AGENT=           # Agent container — errors + distributed traces
PUBLIC_SENTRY_DSN=          # SvelteKit frontend — errors + session replay

# Source map uploads (optional, run during CI/production builds only)
# Get auth token from: https://sentry.io/settings/auth-tokens/
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-frontend-project-slug

# ─── Langfuse Tracing (optional) ──────────────────────────────────────────────
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com