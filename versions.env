# versions.env — SHA pins for upstream Hermes Agent and the Myah plugin.
#
# This file is the single source of truth on the OSS public mirror for
# the versions ./scripts/setup-myah-oss.sh and the oss-e2e-shape CI
# workflow install. On the private monorepo the same pins live in
# agent/Dockerfile.stock; the public repo doesn't ship that file so we
# extract the values here at sync time.
#
# When bumping versions:
#   1. Verify the upstream Hermes release / plugin commit is green.
#   2. Update both lines below.
#   3. Re-run ./scripts/setup-myah-oss.sh on a clean test environment.
#   4. Commit + PR.
#
# Format: shell-source-able. Both consumers ('source ./versions.env').

HERMES_SHA=faa13e49f81480771ceeb55991bb0c27edf1a5fb
MYAH_PLUGIN_SHA=725b61fa0c1913d1830d69f147aa03d8a2d791d6
